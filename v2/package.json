{
  "name": "gt-sararim",
  "version": "2.1.0",
  "description": "تطبيق تعليمي تفاعلي للأطفال المسلمين — يعمل بدون إنترنت",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "pack:linux": "npm run build && electron-builder --config electron-builder.json --linux",
    "pack:win": "npm run build && electron-builder --config electron-builder.json --win",
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "pack:all": "npm run build && electron-builder --config electron-builder.json --linux --win",
    "android:setup": "npm run build && npx cap add android && npx cap sync android",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "npx cap run android",
    "android:build": "npm run build && npx cap sync android && cd android && ./gradlew assembleRelease",
    "android:debug": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@fontsource-variable/geist": "^5.0.0",
    "canvas-confetti": "^1.9.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.476.0",
    "motion": "^12.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@tailwindcss/vite": "^4.1.3",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.1.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.3",
    "tw-animate-css": "^1.2.5",
    "typescript": "^5.8.2",
    "vite": "^6.2.5"
  },
  "keywords": [
    "education",
    "arabic",
    "children",
    "muslim",
    "offline"
  ],
  "license": "GPL-3.0",
  "homepage": "https://salehgnutux.github.io/GT-SARARIM/",
  "author": {
    "name": "SalehGNUTUX",
    "email": "salehoukiki@gmail.com"
  }
}
